{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2017",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
